# ════════════════════════════════════════════════════════════════
#  Token helpers
# ════════════════════════════════════════════════════════════════

def _b64(data: dict) -> str:
    """Base64url-encode a JSON dict (no padding)."""
    return base64.urlsafe_b64encode(
        json.dumps(data, separators=(",", ":")).encode()
    ).decode().rstrip("=")


def _make_token(seq: str, file_id: str, file_name: str,
                mime_type: str, file_size: int) -> str:
    """Build token: 000001_<b64url(meta)>"""
    meta = {
        "fileId": file_id,
        "fileName": file_name,
        "mimeType": mime_type,
        "fileSize": file_size,
    }
    return f"{seq}_{_b64(meta)}"


def _make_hash(token: str) -> str:
    """HMAC-SHA256 of token using SECRET_KEY (hex digest, 16 chars = 64 bits)."""
    sig = hmac.new(
        config.SECRET_KEY.encode(),
        token.encode(),
        hashlib.sha256,
    ).hexdigest()
    return sig[:16]  # 64-bit prefix — short but sufficient for URLs


def _make_urls(token: str) -> tuple[str, str]:
    h = _make_hash(token)
    seq = token.split("_")[0]
    watch = f"{config.WORKER_URL}/watch/{seq}?hash={h}&theme={config.THEME}"
    download = f"{config.WORKER_URL}/file/{token}?hash={h}"
    return watch, download


def _fmt_bytes(n: int) -> str:
    for unit in ("B", "KB", "MB", "GB"):
        if n < 1024:
            return f"{n:.1f} {unit}"
        n /= 1024
    return f"{n:.1f} TB"


