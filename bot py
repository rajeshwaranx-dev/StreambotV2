async def cmd_start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    user = update.effective_user
    is_new = await db.upsert_user(user.id, user.username, user.full_name)

    # Log new user
    if is_new and config.LOG_CHANNEL:
        total = await db.count_users()
        try:
            await context.bot.send_message(
                config.LOG_CHANNEL,
                new_user_log(user.id, user.full_name, user.username, total),
                parse_mode=ParseMode.HTML,
            )
        except Exception:
            pass

    msg = update.effective_message
    if config.START_IMAGE:
        try:
            await msg.reply_photo(
                config.START_IMAGE,
                caption=start_text(user.first_name),
                parse_mode=ParseMode.HTML,
            )
            return
        except Exception:
            pass
    await msg.reply_text(
        start_text(user.first_name),
        parse_mode=ParseMode.HTML,
        disable_web_page_preview=True,
    )


async def cmd_help(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    await update.effective_message.reply_text(
        HELP_TEXT, parse_mode=ParseMode.HTML
    )


@admin_only
async def cmd_stats(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    users = await db.count_users()
    files = await db.count_files()
    channels = await db.count_channels()
    banned = await db.count_banned()
    await update.effective_message.reply_text(
